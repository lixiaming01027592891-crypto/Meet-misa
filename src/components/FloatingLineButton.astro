---
const lineLink = 'https://line.me/R/ti/p/@782faclv';
---

<a 
  href={lineLink} 
  target="_blank" 
  rel="noopener noreferrer"
  id="floating-line"
  class="fixed bottom-6 right-6 z-[9999] flex items-center gap-2.5 bg-gradient-to-r from-[#06C755] to-[#05B34C] text-white px-6 py-4 rounded-full font-bold shadow-line transition-all duration-300 hover:-translate-y-1 hover:scale-105 opacity-0 translate-y-5 pointer-events-none"
  data-track="line"
  aria-label="LINE立即預約"
>
  <img src="/images/line-icon.png" alt="LINE" class="w-7 h-7 rounded-full flex-shrink-0" loading="lazy" />
  <span class="hidden sm:inline">立即LINE預約</span>
</a>

<script>
  const floatingBtn = document.getElementById('floating-line');
  let visible = false;
  
  window.addEventListener('scroll', () => {
    const shouldShow = window.scrollY > 500;
    if (shouldShow && !visible) {
      floatingBtn?.classList.remove('opacity-0', 'translate-y-5', 'pointer-events-none');
      floatingBtn?.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
      visible = true;
    } else if (!shouldShow && visible) {
      floatingBtn?.classList.add('opacity-0', 'translate-y-5', 'pointer-events-none');
      floatingBtn?.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      visible = false;
    }
  });
</script>

<style>
  #floating-line {
    animation: pulseLine 2s infinite;
  }
  @keyframes pulseLine {
    0%, 100% { box-shadow: 0 6px 25px rgba(6, 199, 85, 0.4); }
    50% { box-shadow: 0 6px 35px rgba(6, 199, 85, 0.6); }
  }
</style>
