---
interface Props {
  variant?: 'small' | 'medium' | 'large';
  text?: string;
}

const { variant = 'medium', text = 'LINE免費諮詢' } = Astro.props;
const lineLink = 'https://line.me/R/ti/p/@782faclv';

const sizeStyles = {
  small:
    'inline-flex items-center gap-2 bg-[#06C755] text-white px-5 py-2.5 rounded-full text-sm tracking-wide transition-all duration-300 hover:brightness-110',
  medium:
    'inline-flex items-center gap-2.5 bg-[#06C755] text-white px-7 py-3.5 rounded-full text-base tracking-wide transition-all duration-300 hover:brightness-110',
  large:
    'inline-flex items-center gap-3 bg-[#06C755] text-white px-10 py-5 rounded-full text-lg font-medium tracking-wide transition-all duration-300 hover:brightness-110',
};

const iconSize = {
  small: 'w-4 h-4',
  medium: 'w-5 h-5',
  large: 'w-6 h-6',
};
---

<a
  href={lineLink}
  target="_blank"
  rel="noopener noreferrer"
  class={sizeStyles[variant]}
  data-track="line"
>
  <img
    src="/images/line-icon.png"
    alt=""
    class={`rounded-full flex-shrink-0 ${iconSize[variant]}`}
    loading="lazy"
  />
  {text}
</a>
