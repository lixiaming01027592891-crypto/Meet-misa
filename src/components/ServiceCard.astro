---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  image: string;
  badge?: string;
  features: string[];
  href: string;
}

const { title, description, image, badge, features, href } = Astro.props;
---

<div class="group bg-white rounded-lg shadow-soft overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-strong">
  <div class="relative h-56 overflow-hidden">
    <img 
      src={image} 
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    {badge && (
      <span class="absolute top-4 left-4 bg-gold-gradient text-white px-4 py-1.5 rounded-full text-xs font-bold shadow-gold">
        {badge}
      </span>
    )}
  </div>
  <div class="p-7">
    <h3 class="text-xl font-bold mb-3 text-mi-text">{title}</h3>
    <p class="text-mi-text-light text-sm leading-relaxed mb-4">{description}</p>
    <div class="flex flex-wrap gap-2 mb-5">
      {features.slice(0, 3).map(feature => (
        <span class="bg-mi-cream text-mi-pink-dark px-3 py-1 rounded-full text-xs font-medium">{feature}</span>
      ))}
    </div>
    <a href={href} class="inline-flex items-center gap-1.5 text-mi-pink-dark font-semibold text-sm hover:gap-3 transition-all duration-300">
      了解詳情 →
    </a>
  </div>
</div>
