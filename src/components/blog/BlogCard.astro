---
interface Props {
  title: string;
  description: string;
  image: string;
  publishDate: Date;
  category: string;
  tags: string[];
  slug: string;
  author: string;
  variant?: 'horizontal' | 'vertical';
}

const { title, description, image, publishDate, category, tags, slug, author, variant = 'vertical' } = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

{variant === 'vertical' ? (
  <a href={`/blog/${slug}`} class="group block bg-white rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300 hover:-translate-y-1">
    <div class="relative h-52 overflow-hidden">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <span class="absolute top-3 left-3 bg-gold-gradient text-white px-3 py-1 rounded-full text-xs font-bold">
        {category}
      </span>
    </div>
    <div class="p-6">
      <div class="flex items-center gap-3 text-xs text-mi-text-light mb-3">
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{author}</span>
      </div>
      <h3 class="text-lg font-bold mb-2 group-hover:text-mi-pink-dark transition-colors line-clamp-2">{title}</h3>
      <p class="text-sm text-mi-text-light line-clamp-2">{description}</p>
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.slice(0, 3).map(tag => (
          <span class="bg-mi-cream text-mi-pink-dark px-2 py-0.5 rounded-full text-xs">{tag}</span>
        ))}
      </div>
    </div>
  </a>
) : (
  <a href={`/blog/${slug}`} class="group flex flex-col md:flex-row gap-6 bg-white rounded-lg overflow-hidden shadow-soft hover:shadow-medium transition-all duration-300 hover:-translate-y-1">
    <div class="md:w-2/5 h-52 md:h-auto overflow-hidden flex-shrink-0">
      <img 
        src={image} 
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="p-6 md:py-6 md:pr-6 flex flex-col justify-center">
      <span class="inline-block bg-gold-gradient text-white px-3 py-1 rounded-full text-xs font-bold w-fit mb-3">
        {category}
      </span>
      <div class="flex items-center gap-3 text-xs text-mi-text-light mb-3">
        <span>{formattedDate}</span>
        <span>·</span>
        <span>{author}</span>
      </div>
      <h3 class="text-xl font-bold mb-2 group-hover:text-mi-pink-dark transition-colors">{title}</h3>
      <p class="text-mi-text-light">{description}</p>
    </div>
  </a>
)}

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
