---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '首頁' },
  { href: '/about', label: '關於我們' },
  { href: '/services', label: '服務項目' },
  { href: '/portfolio', label: '作品集' },
  { href: '/blog', label: '部落格' },
  { href: '/faq', label: 'FAQ' },
];

const lineLink = 'https://line.me/R/ti/p/@782faclv';
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300"
  id="header"
>
  <div class="max-w-7xl mx-auto px-6">
    <nav class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div
          class="w-10 h-10 rounded-full bg-[#2D2D2D] flex items-center justify-center text-white text-base font-serif transition-transform duration-300 group-hover:scale-95"
        >
          Mi
        </div>
        <span class="font-serif text-lg tracking-wide text-[#2D2D2D]"
          >遇見Mi美學館</span
        >
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-10">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`text-[0.9rem] tracking-wide transition-colors duration-300 ${
                currentPath === link.href ||
                (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'text-[#2D2D2D] font-medium'
                  : 'text-[#6B6B6B] hover:text-[#2D2D2D]'
              }`}
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={lineLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#2D2D2D] text-white px-7 py-2.5 rounded-full text-sm tracking-wide transition-all duration-300 hover:bg-[#6B6B6B]"
          data-track="line"
        >
          立即預約
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        class="lg:hidden relative w-8 h-8 flex flex-col justify-center items-center"
        id="mobile-toggle"
        aria-label="開啟選單"
        aria-expanded="false"
      >
        <span
          class="hamburger-line absolute w-6 h-[1.5px] bg-[#2D2D2D] transition-all duration-300"
          style="transform: translateY(-6px);"></span>
        <span
          class="hamburger-line absolute w-6 h-[1.5px] bg-[#2D2D2D] transition-all duration-300"
        ></span>
        <span
          class="hamburger-line absolute w-6 h-[1.5px] bg-[#2D2D2D] transition-all duration-300"
          style="transform: translateY(6px);"></span>
      </button>
    </nav>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  class="fixed inset-0 z-40 bg-white opacity-0 invisible transition-all duration-500"
  id="mobile-menu"
>
  <div class="flex flex-col items-center justify-center h-full gap-8">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-link font-serif text-2xl text-[#2D2D2D] tracking-wide opacity-0 translate-y-4 transition-all duration-500"
        >
          {link.label}
        </a>
      ))
    }
    <a
      href={lineLink}
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-link inline-flex items-center gap-2 bg-[#06C755] text-white px-8 py-3.5 rounded-full text-base tracking-wide opacity-0 translate-y-4 transition-all duration-500 mt-4"
      data-track="line"
    >
      <img
        src="/images/line-icon.png"
        alt=""
        class="w-5 h-5 rounded-full"
        loading="lazy"
      />
      立即預約
    </a>
  </div>
</div>

<script>
  const header = document.getElementById('header');
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const hamburgerLines = document.querySelectorAll('.hamburger-line');
  let menuOpen = false;

  // Header scroll shadow effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-[0_1px_0_rgba(0,0,0,0.06)]');
    } else {
      header?.classList.remove('shadow-[0_1px_0_rgba(0,0,0,0.06)]');
    }
  });

  // Toggle mobile menu
  function toggleMenu() {
    menuOpen = !menuOpen;
    mobileToggle?.setAttribute('aria-expanded', String(menuOpen));

    if (menuOpen) {
      // Open menu
      mobileMenu?.classList.remove('opacity-0', 'invisible');
      mobileMenu?.classList.add('opacity-100', 'visible');
      document.body.style.overflow = 'hidden';

      // Animate hamburger to X
      hamburgerLines[0].style.transform = 'rotate(45deg)';
      hamburgerLines[1].style.opacity = '0';
      hamburgerLines[2].style.transform = 'rotate(-45deg)';

      // Stagger fade in links
      mobileLinks.forEach((link, i) => {
        setTimeout(() => {
          link.classList.remove('opacity-0', 'translate-y-4');
          link.classList.add('opacity-100', 'translate-y-0');
        }, 100 + i * 80);
      });
    } else {
      // Close menu
      mobileMenu?.classList.add('opacity-0', 'invisible');
      mobileMenu?.classList.remove('opacity-100', 'visible');
      document.body.style.overflow = '';

      // Reset hamburger
      hamburgerLines[0].style.transform = 'translateY(-6px)';
      hamburgerLines[1].style.opacity = '1';
      hamburgerLines[2].style.transform = 'translateY(6px)';

      // Reset links
      mobileLinks.forEach((link) => {
        link.classList.add('opacity-0', 'translate-y-4');
        link.classList.remove('opacity-100', 'translate-y-0');
      });
    }
  }

  mobileToggle?.addEventListener('click', toggleMenu);

  // Close menu when clicking a link
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (menuOpen) toggleMenu();
    });
  });
</script>
