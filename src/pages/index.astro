---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingLineButton from '../components/FloatingLineButton.astro';
---

<Layout 
  title="遇見Mi美學館 | 台北美睫推薦 - 全台北公認最持久睫毛 | 雙連站美學館"
  description="遇見Mi美學館位於台北雙連站，提供超持久美睫、半永久紋綉、美容美體一站式服務。Google 5.0星評價(224評論)，比男友還持久的睫毛。LINE預約享優惠。"
>
  <!-- Section 1: 頂部信賴列 -->
  <div class="bg-mi-warm h-10 flex items-center justify-center text-xs text-mi-gray tracking-wide">
    <span class="flex items-center gap-2">
      <span>2022 PEA國際冠軍</span>
      <span class="text-mi-camel">·</span>
      <span>SGS安全認證</span>
      <span class="text-mi-camel">·</span>
      <span>完全預約制</span>
    </span>
  </div>

  <!-- Section 2: Header組件 -->
  <Header />

  <!-- Section 3: Hero主視覺 -->
  <section class="bg-white pt-[72px]">
    <div class="container-mi py-16 md:py-24">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- 左：文字內容 -->
        <div class="order-2 lg:order-1 text-center lg:text-left">
          <p class="font-serif text-mi-camel text-lg tracking-widest mb-4">
            遇見最美的自己
          </p>
          <h1 class="font-serif text-4xl md:text-5xl text-mi-dark leading-tight mb-6">
            全台北公認<br>最持久睫毛
          </h1>
          <p class="text-mi-gray leading-relaxed mb-8 max-w-md mx-auto lg:mx-0">
            國際冠軍MiSa老師親自操作，採用SGS認證材料與日本黑膠，客製化眼型設計，讓妳美得安心又持久。位於雙連站30秒，交通便利。
          </p>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start mb-10">
            <a 
              href="https://line.me/R/ti/p/@782faclv" 
              target="_blank" 
              rel="noopener noreferrer"
              class="btn-primary"
              data-track="line"
            >
              立即預約
            </a>
            <a href="#services" class="btn-outline">
              了解更多
            </a>
          </div>
          <!-- 統計數據 -->
          <div class="flex gap-8 justify-center lg:justify-start">
            <div class="text-center">
              <div class="font-serif text-2xl md:text-3xl text-mi-dark">224+</div>
              <div class="text-sm text-mi-gray mt-1">5星好評</div>
            </div>
            <div class="w-px bg-mi-border"></div>
            <div class="text-center">
              <div class="font-serif text-2xl md:text-3xl text-mi-dark">10+</div>
              <div class="text-sm text-mi-gray mt-1">年經驗</div>
            </div>
            <div class="w-px bg-mi-border"></div>
            <div class="text-center">
              <div class="font-serif text-2xl md:text-3xl text-mi-dark">60+</div>
              <div class="text-sm text-mi-gray mt-1">天持久度</div>
            </div>
          </div>
        </div>
        <!-- 右：圖片 -->
        <div class="order-1 lg:order-2">
          <img 
            src="/images/hero-model.jpg" 
            alt="遇見Mi美學館 - 台北美睫推薦，專業美睫服務"
            class="w-full rounded-2xl shadow-medium"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: 品牌標語 -->
  <section class="bg-mi-warm py-20">
    <div class="container-mi text-center">
      <h2 class="font-serif text-2xl md:text-3xl text-mi-dark mb-6">
        讓每一次睜眼，都是自信的開始
      </h2>
      <div class="w-12 h-px bg-mi-camel mx-auto mb-4"></div>
      <p class="text-mi-gray text-sm tracking-wide">
        比男友還持久的睫毛
      </p>
    </div>
  </section>

  <!-- Section 5: 服務項目（3個，圖文交替） -->
  <section id="services" class="bg-white">
    <!-- 服務1: 超持久美睫 -->
    <div class="container-mi py-20 md:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <img 
            src="/images/service-eyelash.jpg" 
            alt="超持久美睫服務 - 6D美睫嫁接"
            class="w-full rounded-2xl shadow-medium"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-serif text-3xl md:text-4xl text-mi-dark mb-4">超持久美睫</h3>
          <p class="text-mi-gray leading-relaxed mb-6">
            國際冠軍技術，採用SGS認證日本黑膠，根據妳的眼型、睫毛條件客製化設計。3D/4D/5D/6D多種款式選擇，接完即可碰水，持久60天以上。
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">3D</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">4D</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">5D</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">6D</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">日本黑膠</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">SGS</span>
          </div>
          <a href="/services/eyelash" class="inline-flex items-center gap-2 text-mi-dark font-medium hover:text-mi-camel transition-colors">
            了解詳情 <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>

    <!-- 服務2: 半永久紋綉 -->
    <div class="bg-mi-warm">
      <div class="container-mi py-20 md:py-28">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="order-2 lg:order-1">
            <h3 class="font-serif text-3xl md:text-4xl text-mi-dark mb-4">半永久紋綉</h3>
            <p class="text-mi-gray leading-relaxed mb-6">
              星柔空氣眉、男士眉、霧唇等紋綉服務。老師畫到滿意才開始操作，無尷尬期，3個月內免費補色，讓妳每天多睡30分鐘。
            </p>
            <div class="flex flex-wrap gap-2 mb-8">
              <span class="px-4 py-1.5 bg-white text-mi-gray text-sm rounded-full">星柔空氣眉</span>
              <span class="px-4 py-1.5 bg-white text-mi-gray text-sm rounded-full">男士眉</span>
              <span class="px-4 py-1.5 bg-white text-mi-gray text-sm rounded-full">霧唇</span>
              <span class="px-4 py-1.5 bg-white text-mi-gray text-sm rounded-full">無尷尬期</span>
              <span class="px-4 py-1.5 bg-white text-mi-gray text-sm rounded-full">免費補色</span>
            </div>
            <a href="/services/embroidery" class="inline-flex items-center gap-2 text-mi-dark font-medium hover:text-mi-camel transition-colors">
              了解詳情 <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <img 
              src="/images/service-embroidery.jpg" 
              alt="半永久紋綉服務 - 星柔空氣眉"
              class="w-full rounded-2xl shadow-medium"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- 服務3: 美容美體 -->
    <div class="container-mi py-20 md:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <img 
            src="/images/service-beauty.jpg" 
            alt="美容美體服務"
            class="w-full rounded-2xl shadow-medium"
            loading="lazy"
          />
        </div>
        <div>
          <h3 class="font-serif text-3xl md:text-4xl text-mi-dark mb-4">美容美體</h3>
          <p class="text-mi-gray leading-relaxed mb-6">
            臉部護理、毛孔清潔、按摩放鬆等美容美體服務。一站式美學體驗，讓妳不用跑很多地方，也能享受全方位的美麗與放鬆。
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">臉部護理</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">毛孔清潔</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">按摩放鬆</span>
            <span class="px-4 py-1.5 bg-mi-warm text-mi-gray text-sm rounded-full">一站式服務</span>
          </div>
          <a href="/services/beauty" class="inline-flex items-center gap-2 text-mi-dark font-medium hover:text-mi-camel transition-colors">
            了解詳情 <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: 為什麼選擇遇見Mi -->
  <section class="bg-mi-beige py-20 md:py-28">
    <div class="container-mi">
      <h2 class="font-serif text-2xl md:text-3xl text-mi-dark text-center mb-16">
        為什麼選擇遇見Mi
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- 卡片1 -->
        <div class="bg-white rounded-2xl p-8 text-center">
          <div class="text-4xl mb-4">🏆</div>
          <h4 class="font-medium text-mi-dark mb-2">國際冠軍</h4>
          <p class="text-mi-gray text-sm leading-relaxed">2022 PEA國際6D美睫冠軍親自操作，技術有保證</p>
        </div>
        <!-- 卡片2 -->
