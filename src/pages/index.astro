        <a href="tel:0989260867" class="inline-flex items-center gap-2 text-white px-8 py-3.5 rounded-full font-medium text-sm tracking-wider border border-white/30 hover:bg-white/10 transition-all duration-300">
          撥打電話
        </a>
      </div>
    </div>
  </section>

  <!-- Section 11: Footer -->
  <Footer />

  <!-- Section 12: Floating LINE Button -->
  <FloatingLineButton />
</Layout>
