          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-mi-warm flex items-center justify-center text-mi-dark font-medium text-sm">N</div>
            <div>
              <div class="text-mi-dark font-medium text-sm">奈奈</div>
              <div class="text-mi-gray text-xs">星柔空氣眉</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 8: 作品集 -->
  <section class="bg-mi-warm py-20 md:py-28">
    <div class="container-mi">
      <h2 class="font-serif text-2xl md:text-3xl text-mi-dark text-center mb-12">真實改造效果</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="overflow-hidden rounded-xl group cursor-pointer">
          <img 
            src="/images/before-after-1.jpg" 
            alt="美睫前後對比"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="overflow-hidden rounded-xl group cursor-pointer">
          <img 
            src="/images/before-after-2.jpg" 
            alt="霧眉前後對比"
            class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="overflow-hidden rounded-xl group cursor-pointer">
          <img 
            src="/images/service-eyelash.jpg" 
