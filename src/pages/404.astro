---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = '頁面找不到 | 遇見Mi美學館';
---

<Layout title={pageTitle} noindex={true}>
  <Header />
  
  <section class="min-h-[70vh] flex items-center justify-center pt-[72px] bg-gradient-to-br from-mi-cream to-mi-white">
    <div class="text-center px-6">
      <div class="text-8xl font-extrabold text-gradient-gold mb-4">404</div>
      <h1 class="text-3xl font-bold mb-4">哎呀！頁面找不到</h1>
      <p class="text-mi-text-light mb-8 max-w-md mx-auto">
        您要找的頁面可能已經被移除了，或者網址輸入錯誤。別擔心，帶您回到首頁！
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="btn-primary">回到首頁</a>
        <a href="/services/eyelash" class="btn-secondary">查看美睫服務</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
